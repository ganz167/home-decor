---
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: post }));
}
const post = Astro.props;
const { Content } = await post.render();
---
<html lang="en">
<head><title>{post.data.title} | Ganzo Decor</title></head>
<body style="font-family:system-ui; max-width:700px; margin:0 auto; padding:40px; line-height:1.6">
  <a href="/blog">← Back to Journal</a>
  <h1>{post.data.title}</h1>
  <p style="color:#666">{post.data.pubDate.toDateString()}</p>
  <Content />
</body>
</html>
