---
const posts = await Astro.glob('../../content/blog/*.md');
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog - Ganzo Decor</title>
  <style>
    body { font-family: system-ui; max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem; background: #faf9f7; color: #2c2c2a; }
    h1 { font-family: Georgia, serif; font-size: 2rem; margin-bottom: 0.25rem; }
    .subtitle { color: #888; margin-bottom: 2.5rem; font-size: 0.95rem; }
    .post-card { border: 1px solid #e8e6e0; border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 1rem; background: #fff; }
    .post-card h2 { font-family: Georgia, serif; font-size: 1.2rem; margin: 0 0 0.4rem; }
    .post-card p { font-size: 0.9rem; color: #666; margin: 0 0 0.75rem; }
    .post-card a { color: #3b6d11; font-size: 0.9rem; font-weight: 600; text-decoration: none; }
    .post-card a:hover { text-decoration: underline; }
    nav { font-size: 0.9rem; margin-bottom: 2rem; }
    nav a { color: #3b6d11; text-decoration: none; margin-right: 1rem; }
  </style>
</head>
<body>
  <nav><a href="/">← Home</a></nav>
  <h1>Ganzo Decor Journal</h1>
  <p class="subtitle">Budget decor ideas for renters & small spaces</p>
  {posts.map((post) => (
    <div class="post-card">
      <h2>{post.frontmatter.title}</h2>
      <p>{post.frontmatter.description}</p>
      <a href={`/blog/${post.file.split('/').pop().replace('.md', '')}`}>Read post →</a>
    </div>
  ))}
</body>
</html>
