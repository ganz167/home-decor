---
export async function getStaticPaths() {
  const posts = await Astro.glob('../../../content/blog/*.md');
  return posts.map((post) => ({
    params: { slug: post.file.split('/').pop().replace('.md', '') },
    props: { post },
  }));
}
const { post } = Astro.props;
const { Content, frontmatter } = post;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={frontmatter.description} />
  <title>{frontmatter.title} - Ganzo Decor</title>
  <style>
    body { font-family: Georgia, serif; max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem; color: #2c2c2a; background: #faf9f7; line-height: 1.8; }
    h1 { font-size: 2rem; line-height: 1.3; margin-bottom: 0.5rem; color: #1a1a18; }
    h2 { font-size: 1.4rem; margin-top: 2.5rem; color: #1a1a18; border-bottom: 1px solid #e8e6e0; padding-bottom: 0.4rem; }
    img { width: 100%; border-radius: 8px; margin: 1.5rem 0; }
    a { color: #3b6d11; }
    .meta { font-family: system-ui; font-size: 0.85rem; color: #888; margin-bottom: 2rem; }
    .disclosure { background: #f0f7ea; border-left: 3px solid #639922; padding: 0.75rem 1rem; font-family: system-ui; font-size: 0.85rem; color: #3b6d11; border-radius: 0 6px 6px 0; margin: 1.5rem 0; }
    .amazon-btn { display: inline-block; background: #3b6d11; color: #fff; font-family: system-ui; font-size: 0.9rem; font-weight: 600; padding: 0.6rem 1.2rem; border-radius: 6px; text-decoration: none; margin: 0.5rem 0 1rem; }
    .amazon-btn:hover { background: #2d5409; }
    nav { font-family: system-ui; font-size: 0.9rem; margin-bottom: 2rem; }
    nav a { color: #3b6d11; text-decoration: none; margin-right: 1rem; }
  </style>
</head>
<body>
  <nav>
    <a href="/">← Home</a>
    <a href="/blog">All Posts</a>
  </nav>
  <h1>{frontmatter.title}</h1>
  <div class="meta">{frontmatter.author} · {frontmatter.pubDate}</div>
  <Content />
</body>
</html>
