---
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<html lang="en">
<head>
  <title>Journal | Ganzo Decor</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body style="font-family:system-ui; max-width:800px; margin:0 auto; padding:40px">
  <h1>Ganzo Decor Journal</h1>
  <a href="/">← Home</a>
  
  {posts.map((post) => (
    <article style="margin:40px 0; border-bottom:1px solid #eee; padding-bottom:20px">
      <h2><a href={`/blog/${post.slug}`} style="text-decoration:none; color:#222">{post.data.title}</a></h2>
      <p style="color:#666; font-size:14px">{post.data.pubDate.toDateString()}</p>
      <p>{post.data.description}</p>
    </article>
  ))}
</body>
</html>
